# MongoDB Atlas connection string
MONGODB_URI=
# Comma-separated list of allowed frontend origins (Vercel URL + local dev)
CORS_ALLOWED_ORIGINS=

# JWT secret - MUST be a long random string (256+ bits) in production
JWT_SECRET=
JWT_ACCESS_EXP_MS=
JWT_REFRESH_EXP_MS=

# Bootstrap admin account - created automatically on first boot if it doesn't exist
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
